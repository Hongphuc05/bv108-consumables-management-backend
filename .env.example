# Backend runtime
SERVER_PORT=8080
GIN_MODE=debug
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=hospital_db
# Leave empty to use the driver default, or set a MySQL TLS mode explicitly.
DB_TLS=

# Authentication
JWT_SECRET=change-me
JWT_EXPIRES_HOURS=8
JWT_EXPIRES_MINUTES=0

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
SMTP_FROM=
# mandatory | opportunistic | notls
SMTP_TLS_POLICY=mandatory
DEFAULT_COMPANY_CONTACT_EMAIL=

# Internal supply sync
INTERNAL_SUPPLY_API_URL=
INTERNAL_SUPPLY_API_TOKEN=
INTERNAL_SUPPLY_API_COOKIE=
INTERNAL_SUPPLY_API_BODY={}
INTERNAL_SUPPLY_API_TIMEOUT_SECONDS=120
INTERNAL_SUPPLY_SYNC_ENABLED=false
INTERNAL_SUPPLY_SYNC_HOUR=20
INTERNAL_SUPPLY_SYNC_MINUTE=0
INTERNAL_SUPPLY_SYNC_TIMEZONE=Asia/Bangkok
INTERNAL_SUPPLY_SYNC_RUN_ON_STARTUP=false

# Vinmes purchase-order catalog API (internal network)
VINMES_API_BASE_URL=
VINMES_API_TOKEN=
VINMES_API_TIMEOUT_SECONDS=60

# Gemini report assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
# Keep the default in production; override for a compatible proxy or local test server.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_WEB_SEARCH=false
GEMINI_MAX_OUTPUT_TOKENS=4096
